{
  "name": "@rejc2/projecttemplate-server",
  "packageManager": "yarn@4.12.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:info": "tsx scripts/write-build-info.ts",
    "build": "yarn generate",
    "dev": "yarn build:info && tsx watch --env-file=.env src/index.ts",
    "generate": "yarn build:info && yarn prisma:generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "start": "yarn build:info && tsx --env-file=.env src/index.ts",
    "lint": "eslint .",
    "lint:strict": "yarn lint --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.seed.json"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "bcrypt": "^6.0.0",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.6",
    "express": "^5.1.0",
    "express-session": "^1.19.0",
    "ioredis": "^5.9.3",
    "nullthrows": "^1.1.1",
    "pg": "^8.18.0",
    "temporal-polyfill": "^0.3.2"
  },
  "devDependencies": {
    "@rejc2/projecttemplate-eslint-config": "workspace:*",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.2",
    "@types/express-session": "^1.18.1",
    "@types/ioredis-mock": "^8.2.6",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.39.2",
    "ioredis-mock": "^8.13.1",
    "prisma": "^7.0.0",
    "prisma-mock": "^1.1.0",
    "supertest": "^7.1.0",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vitest-mock-extended": "^3.1.0"
  }
}
