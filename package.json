{
  "name": "@rejc2/project-template-monorepo",
  "packageManager": "yarn@4.12.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "yarn workspaces foreach --all --topological run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "yarn workspaces foreach --all run lint",
    "lint:strict": "yarn workspaces foreach --all run lint:strict",
    "test": "yarn workspaces foreach --all run test",
    "typecheck": "yarn workspaces foreach --all run typecheck",
    "validate:yaml": "node scripts/validate-yaml-schemas.js"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "test-packages/*"
  ],
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-prisma": "^5.0.0",
    "yaml": "^2.8.2"
  }
}
